# Copy to .env and adjust.

DJANGO_SECRET_KEY=change-me-in-development
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Password reset emails: link in the email points to this SPA origin + /reset-password?uid=…&token=…
PASSWORD_RESET_FRONTEND_BASE_URL=http://localhost:5173

# Email (defaults to console backend — reset links print to the server terminal)
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For SMTP (e.g. production):
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=Osolot <noreply@example.com>

# Database
#
# SQLite (default): omit DATABASE_BACKEND or set:
# DATABASE_BACKEND=sqlite
#
# PostgreSQL: set DATABASE_BACKEND=postgresql and the connection fields below.
# Requires the psycopg package (see server/requirements.txt).
#
# DATABASE_BACKEND=postgresql
# POSTGRES_DB=osolot
# POSTGRES_USER=osolot
# POSTGRES_PASSWORD=change-me
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
#
# Optional SSL (e.g. managed Postgres): set to require or verify-full
# POSTGRES_SSLMODE=require
